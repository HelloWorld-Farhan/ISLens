<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/islBgScreen"
    android:fitsSystemWindows="true">

    <!-- TOP GRADIENT -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/gradient_top"
        android:layout_gravity="top" />

    <!-- TOP APP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/histTopBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:paddingHorizontal="16dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/histBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Go back"
            android:background="@drawable/icon_btn_bg"
            android:padding="10dp"
            android:scaleType="fitCenter"
            app:tint="#00E5FF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title: ISLens -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ISL"
                android:textColor="#00E5FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ens"
                android:textColor="?attr/islTextPrimary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <!-- Right side: HISTORY badge only (Feedback button REMOVED) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● HISTORY"
            android:textColor="#00E5FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:background="@drawable/badge_live_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="64dp"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="16dp">

        <!-- SEARCH BAR -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/islBgCard"
            app:cardCornerRadius="16dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp">

                <TextView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:text="🔍"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginEnd="10dp" />

                <EditText
                    android:id="@+id/histSearchBox"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search by sentence, date or time..."
                    android:textColorHint="?attr/islTextHint"
                    android:textColor="?attr/islTextPrimary"
                    android:textSize="13sp"
                    android:background="@null"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TITLE ROW + CLEAR ALL BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📋  Sentence History"
                android:textColor="?attr/islTextPrimary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/histClearAllButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:text="🗑  Clear All"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                app:backgroundTint="#D50000"
                app:cornerRadius="10dp"
                app:elevation="3dp" />
        </LinearLayout>

        <!-- EMPTY STATE TEXT -->
        <TextView
            android:id="@+id/histEmptyText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No history yet.\n\nTap the Save button next to the sentence\nto save it here."
            android:textColor="?attr/islTextHint"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.6"
            android:layout_marginTop="60dp"
            android:visibility="visible" />

        <!-- HISTORY LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/histRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <!-- FOOTER STRIP -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="?attr/islBgCard"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ISLens"
                    android:textColor="?attr/islTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/islDivider"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="© 2026 ISLens · All Rights Reserved"
                    android:textColor="?attr/islTextLabel"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>