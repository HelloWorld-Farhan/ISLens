<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/islBgScreen"
    android:fitsSystemWindows="true">

    <!-- TOP GRADIENT -->
    <View
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@drawable/gradient_top"
        android:layout_gravity="top" />

    <!-- TOP APP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/settingsBackButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Go back"
            android:background="@drawable/icon_btn_bg"
            android:padding="10dp"
            android:scaleType="fitCenter"
            app:tint="#00E5FF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ISL"
                android:textColor="#00E5FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ens"
                android:textColor="?attr/islTextPrimary"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● SETTINGS"
            android:textColor="#00E5FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:background="@drawable/badge_live_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="64dp"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- ══ APPEARANCE ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="?attr/islBgCard"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <View android:layout_width="4dp" android:layout_height="22dp"
                            android:background="#00E5FF" android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="APPEARANCE"
                            android:textColor="#00E5FF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:fontFamily="sans-serif-condensed" />
                    </LinearLayout>

                    <!-- Description text -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Choose how ISLens looks. Default follows your phone's system setting automatically."
                        android:textColor="?attr/islTextLabel"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="14dp" />

                    <!-- THREE THEME BUTTONS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">

                        <!-- Default Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/themeBtnDefault"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="📱 Default"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingVertical="10dp"
                            app:backgroundTint="?attr/islBgCard"
                            app:strokeColor="#00E5FF"
                            app:strokeWidth="2dp"
                            app:cornerRadius="12dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                        <!-- Light Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/themeBtnLight"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="☀️ Light"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingVertical="10dp"
                            app:backgroundTint="?attr/islBgCard"
                            app:strokeColor="#00E5FF"
                            app:strokeWidth="2dp"
                            app:cornerRadius="12dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                        <!-- Dark Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/themeBtnDark"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌙 Dark"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingVertical="10dp"
                            app:backgroundTint="?attr/islBgCard"
                            app:strokeColor="#00E5FF"
                            app:strokeWidth="2dp"
                            app:cornerRadius="12dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    </LinearLayout>

                    <!-- Current selection label -->
                    <TextView
                        android:id="@+id/themeSelectedLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📱 Default (follows phone)"
                        android:textColor="#00E5FF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="?attr/islBanner"
                        android:paddingVertical="8dp"
                        android:paddingHorizontal="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ SOUND ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="?attr/islBgCard"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <View android:layout_width="4dp" android:layout_height="22dp"
                            android:background="#00C853" android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SOUND"
                            android:textColor="#00C853"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:fontFamily="sans-serif-condensed" />
                    </LinearLayout>

                    <!-- Sound ON/OFF Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/islBanner"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="22sp"
                            android:layout_height="22sp"
                            android:text="🔊"
                            android:textSize="18sp"
                            android:gravity="center"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Button Sounds"
                            android:textColor="?attr/islTextPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/soundSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />
                    </LinearLayout>

                    <!-- Sound Picker Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="?attr/islBanner"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="22sp"
                                android:layout_height="22sp"
                                android:text="🎵"
                                android:textSize="18sp"
                                android:gravity="center"
                                android:layout_marginEnd="12dp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Choose Sound"
                                    android:textColor="?attr/islTextPrimary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/currentSoundLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Default notification sound"
                                    android:textColor="?attr/islTextLabel"
                                    android:textSize="11sp"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="end"
                                    android:singleLine="true" />
                            </LinearLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/pickSoundBtn"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:text="🎵  Pick Sound from Phone"
                            android:textColor="#0A0A0F"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:backgroundTint="#00C853"
                            app:cornerRadius="10dp"
                            app:elevation="2dp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ VIBRATION ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="?attr/islBgCard"
                app:cardCornerRadius="18dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Section header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <View android:layout_width="4dp" android:layout_height="22dp"
                            android:background="#FF9800" android:layout_marginEnd="10dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VIBRATION"
                            android:textColor="#FF9800"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15"
                            android:fontFamily="sans-serif-condensed" />
                    </LinearLayout>

                    <!-- Vibration Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="?attr/islBanner"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="14dp">

                        <TextView
                            android:layout_width="22sp"
                            android:layout_height="22sp"
                            android:text="📳"
                            android:textSize="18sp"
                            android:gravity="center"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Button Vibration"
                            android:textColor="?attr/islTextPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/vibrationSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ FOOTER ══ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="?attr/islBgCard"
                app:cardCornerRadius="18dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="20dp"
                    android:paddingVertical="20dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/isl_logo"
                        android:scaleType="fitCenter"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ISLens"
                        android:textColor="?attr/islTextPrimary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Real-Time Indian Sign Language Recognition"
                        android:textColor="#00E5FF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/islDivider"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="© 2026 ISLens · All Rights Reserved"
                        android:textColor="?attr/islTextLabel"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unauthorised copying, distribution, or modification\nof this app is strictly prohibited."
                        android:textColor="?attr/islTextLabel"
                        android:textSize="9sp"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>