<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0A0A0F">
    <!-- Current Language -->
    <TextView
        android:id="@+id/currentLanguageText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current: English"
        android:textColor="#00E5FF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <!-- Search Bar -->
    <EditText
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/glass_card_bg"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:drawablePadding="12dp"
        android:hint="Search languages..."
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#60FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        android:importantForAutofill="no"
        android:inputType="text" />

    <!-- Language List (Scrollable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="400dp">

        <LinearLayout
            android:id="@+id/languageList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>
</LinearLayout>