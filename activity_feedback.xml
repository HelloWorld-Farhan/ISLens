<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/islBgScreen"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="40dp">

        <!-- TOP BAR -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp">

            <ImageButton
                android:id="@+id/feedbackBackButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Go back"
                android:background="@drawable/icon_btn_bg"
                android:padding="10dp"
                android:scaleType="fitCenter"
                app:tint="#00E5FF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ISL"
                    android:textColor="#00E5FF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-condensed" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ens"
                    android:textColor="?attr/islTextPrimary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:fontFamily="sans-serif-condensed" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● FEEDBACK"
                android:textColor="#00E5FF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:background="@drawable/badge_live_bg"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- HEADER CARD — Rate ISLens -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="?attr/islBgCard"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rate ISLens"
                    android:textColor="?attr/islTextPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your feedback helps us improve sign language accessibility for everyone"
                    android:textColor="?attr/islTextLabel"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="20dp" />

                <!-- FIX: Use a LayerDrawable or set star color programmatically -->
                <RatingBar
                    android:id="@+id/feedbackRatingBar"
                    style="?android:attr/ratingBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:numStars="5"
                    android:rating="0"
                    android:stepSize="1"
                    android:layout_marginBottom="8dp"
                    android:theme="@style/GoldRatingBar" />

                <TextView
                    android:id="@+id/ratingLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap to rate"
                    android:textColor="#00E5FF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- FORM CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="?attr/islBgCard"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- NAME FIELD (NEW) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR NAME"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/feedbackNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Your full name"
                    android:textColor="?attr/islTextPrimary"
                    android:textColorHint="?attr/islTextHint"
                    android:textSize="14sp"
                    android:inputType="textPersonName"
                    android:background="@drawable/spinner_dark_bg"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="16dp" />

                <!-- EMAIL FIELD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR EMAIL"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/feedbackEmailInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="your@email.com"
                    android:textColor="?attr/islTextPrimary"
                    android:textColorHint="?attr/islTextHint"
                    android:textSize="14sp"
                    android:inputType="textEmailAddress"
                    android:background="@drawable/spinner_dark_bg"
                    android:paddingHorizontal="14dp"
                    android:layout_marginBottom="16dp" />

                <!-- FEEDBACK FIELD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YOUR FEEDBACK"
                    android:textColor="#00E5FF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/feedbackDescInput"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:hint="Tell us what you love, what could be better, or any issues you faced..."
                    android:textColor="?attr/islTextPrimary"
                    android:textColorHint="?attr/islTextHint"
                    android:textSize="14sp"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:background="@drawable/spinner_dark_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="We'll send a confirmation to your email. This info is used only to process your feedback."
                    android:textColor="?attr/islTextLabel"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp" />

                <ProgressBar
                    android:id="@+id/feedbackProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:visibility="gone"
                    android:layout_marginBottom="10dp"
                    android:indeterminateTint="#00E5FF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/submitFeedbackBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Submit Feedback"
                    android:textColor="#000000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    app:backgroundTint="#00E5FF"
                    app:cornerRadius="14dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- FOOTER CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="?attr/islBgCard"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ISLens"
                    android:textColor="?attr/islTextPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/islDivider"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="© 2026 ISLens · All Rights Reserved"
                    android:textColor="?attr/islTextLabel"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>