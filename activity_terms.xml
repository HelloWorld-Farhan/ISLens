<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/islBgScreen">

    <!-- ════════════════════════════════════════════
         TOP HEADER  (constrained to top)
    ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/termsHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- App Logo Row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ISL"
                android:textColor="#00E5FF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ens"
                android:textColor="?attr/islTextPrimary"
                android:textSize="30sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Terms of Service &amp; Privacy Policy"
            android:textColor="?attr/islTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please read and scroll to the bottom to continue"
            android:textColor="?attr/islTextLabel"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- ════════════════════════════════════════════
         SCROLLABLE TERMS CONTENT
         Fills all space between header and footer.
         The LinearLayout inside (termsContentContainer)
         is populated entirely from Java — no static
         terms text lives here.
    ════════════════════════════════════════════ -->
    <ScrollView
        android:id="@+id/termsScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="20dp"
        android:scrollbars="vertical"
        android:overScrollMode="always"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/termsHeader"
        app:layout_constraintBottom_toTopOf="@id/termsFooter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/termsContentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="20dp">

            <!--
                All section headings and body text are
                injected here programmatically by
                TermsActivity.populateTerms().
                Do NOT add static TextViews here.
            -->

        </LinearLayout>
    </ScrollView>

    <!-- ════════════════════════════════════════════
         BOTTOM ACCEPT PANEL  (constrained to bottom)
    ════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/termsFooter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/islBgCard"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="24dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Checkbox Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <CheckBox
                android:id="@+id/acceptCheckBox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:alpha="0.4"
                android:buttonTint="#00E5FF"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="I have read and agree to the Terms of Service and Privacy Policy"
                android:textColor="?attr/islTextSecondary"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/acceptButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Accept &amp; Continue"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#00E5FF"
            app:cornerRadius="14dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>